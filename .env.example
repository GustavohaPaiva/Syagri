# Copie para .env na raiz ( .env NÃO vai para o Git ).
# Os nomes das variáveis abaixo devem ser os MESMOS do seu .env local.
# No GitHub: Settings → Secrets and variables → Actions → New repository secret.

# URL do projeto Supabase (Dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anon / public (Dashboard → API → anon key). Nunca use service_role aqui.
VITE_SUPABASE_ANON_KEY=eyJ...sua-chave-anon-publica
