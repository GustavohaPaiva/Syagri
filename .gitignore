# =============================================================================
# Syagri — .gitignore para repositório público + GitHub Pages
# O site é publicado a partir do build (dist/) gerado no CI, não do código-fonte.
# =============================================================================

# --- Dependências ---
node_modules/

# --- Build / artefatos de deploy ---
# Não commitar dist: o workflow do GitHub Pages gera o build com secrets do repositório.
dist/
dist-ssr/
build/
out/

# --- Vite / bundlers ---
.vite/
*.tsbuildinfo

# --- Variáveis de ambiente e segredos (NUNCA commitar) ---
.env
.env.*
!.env.example

# Chaves, certificados e credenciais avulsas
*.pem
*.key
*.p12
*.pfx
credentials.json
secrets.json
service-account*.json
**/supabase/.env
**/supabase/.env.*

# Supabase CLI — estado local (pode conter tokens de sessão)
supabase/.branches/
supabase/.temp/
.branches/

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Testes e cobertura ---
coverage/
.nyc_output/

# --- Cache de ferramentas ---
.eslintcache
.cache/
.parcel-cache/
.turbo/

# --- SO ---
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# --- Editores / IDE ---
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- Cursor / agentes (estado local da máquina) ---
.cursor/projects/
.cursor/**/*.log

# --- Hospedagem alternativa (não usada aqui, por precaução) ---
.vercel/
.netlify/

# --- Arquivos temporários ---
*.local
*~
~$*
